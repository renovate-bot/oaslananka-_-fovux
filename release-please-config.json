{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    "fovux-mcp": {
      "release-type": "python",
      "component": "fovux-mcp",
      "package-name": "fovux-mcp",
      "changelog-path": "CHANGELOG.md",
      "include-component-in-tag": true,
      "bump-patch-for-minor-pre-major": true,
      "extra-files": [
        {
          "type": "generic",
          "path": "src/fovux/__init__.py"
        },
        {
          "type": "json",
          "path": "server.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "server.json",
          "jsonpath": "$.packages[0].version"
        },
        {
          "type": "yaml",
          "path": "smithery.yaml",
          "jsonpath": "$.version"
        }
      ]
    },
    "fovux-studio": {
      "release-type": "node",
      "component": "fovux-studio",
      "package-name": "fovux-studio",
      "changelog-path": "CHANGELOG.md",
      "include-component-in-tag": true,
      "bump-patch-for-minor-pre-major": true
    }
  },
  "separate-pull-requests": false,
  "always-update": true,
  "pull-request-title-pattern": "chore${scope}: release${component} ${version}",
  "group-pull-request-title-pattern": "chore(release): release fovux",
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "fovux",
      "components": ["fovux-mcp", "fovux-studio"]
    }
  ],
  "pull-request-header": "## Release Summary",
  "pull-request-footer": "Release managed by release-please manifest mode."
}
